// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("OPERATOR") // ADMIN, SUPERVISOR, OPERATOR
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id                  Int        @id @default(autoincrement())
  name                String     @unique
  color               String     @default("emerald")
  recoveryTarget      Float      @default(70.0)
  description         String?
  logs                WasteLog[]
  active              Boolean    @default(true)
}

model WasteLog {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  confidence  Float
  line        String   @default("LINE_A")
  imagePath   String?
  timestamp   DateTime @default(now())
}

model Report {
  id          Int      @id @default(autoincrement())
  title       String
  type        String   @default("ESG") // ESG, OPERATIONAL, COMPLIANCE
  data        String   // JSON string of report data
  author      String
  createdAt   DateTime @default(now())
}
